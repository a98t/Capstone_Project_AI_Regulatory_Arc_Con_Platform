# ============================================================
# DEREK-AI Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================================

# --- LLM Configuration ---
# Choose: "ollama" (free, local) or "openai" (paid, better quality)
LLM_PROVIDER=ollama

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct

# --- Embedding Configuration ---
# Always local — no API key needed
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_BATCH_SIZE=32

# --- Vector Database (Qdrant) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=regulations

# --- RAG Configuration ---
RAG_TOP_K=8
RAG_CONFIDENCE_THRESHOLD=0.60
RAG_MAX_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100

# --- MCP / Tavily ---
TAVILY_API_KEY=tvly-your-key-here
MCP_CACHE_TTL_HOURS=24

# --- Langfuse Observability ---
# Get free keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=20
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Security ---
# Set to a long random string
SECRET_KEY=change-me-to-a-random-64-char-string

# --- Data Paths ---
REGULATIONS_DIR=./data/regulations
CACHE_DIR=./data/cache
SQLITE_DB_PATH=./data/derek_ai.db

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
